{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "packageManager": "pnpm@10.25.0",
  "scripts": {
    "preinstall": "node ./scripts/ensure-pnpm.mjs",
    "dev": "corepack pnpm --filter @workspace/api-server --filter @workspace/logomatch-ai --parallel run dev",
    "dev:api": "corepack pnpm --filter @workspace/api-server run dev",
    "dev:web": "corepack pnpm --filter @workspace/logomatch-ai run dev",
    "dev:stop": "node ./scripts/stop-dev.mjs",
    "build": "corepack pnpm run typecheck && corepack pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "corepack pnpm run typecheck:libs && corepack pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "typescript": "~5.9.2",
    "prettier": "^3.8.1"
  }
}
